# ---------------------------------------------------------------------------
# Intraday Signal Engine — environment template
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# ---------------------------------------------------------------------------

# --- Runtime mode -----------------------------------------------------------
# Data source: "mock" (synthetic, default), "yahoo_nse" (free real NSE data via
# yfinance, no API key), or "dhan" (paid Dhan Data API subscription required).
SE_DATA_SOURCE=mock
# News source: "mock" (synthetic) or "rss" (live Moneycontrol/ET headlines, no API key).
SE_NEWS_SOURCE=mock
# Global cues source: "mock" (synthetic) or "yahoo" (live yfinance, no API key).
SE_CUES_SOURCE=mock

# Hard safety switch. Live order execution is NOT implemented in this tool.
# This flag exists only so the value is explicit and auditable; leave it false.
SE_ALLOW_LIVE_ORDERS=false

# --- Free real-time data (choose ONE) ----------------------------------------

# Option A: Yahoo Finance NSE (free, 15-min delayed, no account, no setup)
# Set SE_DATA_SOURCE=yahoo_nse. No other vars needed.

# Option B: Angel One SmartAPI (free, real-time, needs Angel One demat account)
# Account: angelone.in → free to open, zero brokerage.
# Setup: Profile → API Access → Create App → enable TOTP → scan QR with Authenticator.
# Then set SE_DATA_SOURCE=angelone and fill in the vars below.
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# Option C: Dhan Data API (paid, ~₹500/month; already have credentials)
# Set SE_DATA_SOURCE=dhan. Requires active Dhan Data API subscription (DH-902 = not subscribed).
DHAN_CLIENT_ID=1112274995
DHAN_ACCESS_TOKEN=
# In-dashboard OTP login (consent flow): create an API key+secret in the Dhan portal (valid
# 12 months) and register DHAN_REDIRECT_URL there. Lets the dashboard refresh the 24h token
# via OTP instead of manual portal regen. DHAN_REDIRECT_URL = your Vercel callback, e.g.
# https://<your-app>.vercel.app/api/dhan/callback
DHAN_API_KEY=
DHAN_API_SECRET=
DHAN_REDIRECT_URL=

# --- Alerts (optional) ------------------------------------------------------
# Alerter backend: "console" (default), "telegram", "callmebot" (free WhatsApp),
# or "whatsapp" (Meta Cloud API, needs business account).
SE_ALERTER=console

# Telegram (SE_ALERTER=telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CallMeBot — FREE WhatsApp to any personal number, no Meta business account needed.
# Activation (once, on your phone — takes 2 min):
#   1. Add +34 694 23 67 31 to contacts as "CallMeBot"
#   2. Send it: I allow callmebot to send me messages
#   3. Reply contains your API key — put it below.
#   See: https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+918359980149
CALLMEBOT_APIKEY=

# WhatsApp Cloud API (Meta) — only needed if SE_ALERTER=whatsapp (needs Meta business account).
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_TO=

# --- API (dashboard backend) ------------------------------------------------
# If set, every /api route requires header X-API-Key == this value. Leave blank in local dev.
SE_API_TOKEN=
# Comma-separated allowed origins for CORS. Set to your Vercel URL in production ("*" in dev).
SE_CORS_ORIGINS=*

# --- Deploy helper (run-with-tunnel.sh) -------------------------------------
# Vercel CLI token + scope, used only by run-with-tunnel.sh to repoint the hosted
# dashboard at a local Cloudflare Quick Tunnel. Create at vercel.com → Account → Tokens.
VERCEL_TOKEN=
VERCEL_SCOPE=

# --- Storage (local defaults need no server) --------------------------------
# SQLite path for signals/paper-trades/audit (Postgres is the production target).
SE_DB_URL=sqlite:///data/signal_engine.sqlite3
# Parquet root for historical bars.
SE_PARQUET_DIR=data/parquet
