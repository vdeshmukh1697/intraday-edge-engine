# ---------------------------------------------------------------------------
# Intraday Signal Engine — environment template
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# ---------------------------------------------------------------------------

# --- Runtime mode -----------------------------------------------------------
# Data source for the engine: "mock" (synthetic, default, no network/market) or
# "dhan" (live Dhan feed — read-only market data; orders are NEVER placed).
SE_DATA_SOURCE=mock
# News source: "mock" (synthetic) or "rss" (live Moneycontrol/ET headlines, no API key).
SE_NEWS_SOURCE=mock
# Global cues source: "mock" (synthetic) or "yahoo" (live yfinance, no API key).
SE_CUES_SOURCE=mock

# Hard safety switch. Live order execution is NOT implemented in this tool.
# This flag exists only so the value is explicit and auditable; leave it false.
SE_ALLOW_LIVE_ORDERS=false

# --- Dhan API (only needed if SE_DATA_SOURCE=dhan; market-data only) ---------
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# --- Alerts (optional) ------------------------------------------------------
# Alerter backend: "console" (default), "telegram", "whatsapp".
SE_ALERTER=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# WhatsApp Cloud API (Meta) — only needed if SE_ALERTER=whatsapp. Personal use only.
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_TO=

# --- API (dashboard backend) ------------------------------------------------
# If set, every /api route requires header X-API-Key == this value. Leave blank in local dev.
SE_API_TOKEN=
# Comma-separated allowed origins for CORS. Set to your Vercel URL in production ("*" in dev).
SE_CORS_ORIGINS=*

# --- Storage (local defaults need no server) --------------------------------
# SQLite path for signals/paper-trades/audit (Postgres is the production target).
SE_DB_URL=sqlite:///data/signal_engine.sqlite3
# Parquet root for historical bars.
SE_PARQUET_DIR=data/parquet
